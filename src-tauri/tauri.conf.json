{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MSPro-Ltd Corp",
  "version": "1.0.35",
  "identifier": "ru.msproltd.corp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MSPro-Ltd Corp",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/mspro-rollback-helper.exe": "mspro-rollback-helper.exe"
    },
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      },
      "allowDowngrades": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vladimirspecalp-hub/MSPro-Ltd-Corp-1.0/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0RDk2ODlFRjcwNkNCNjAKUldSZ3l3YjNubWpabFBhTmhSZ3JUOGh3L2g0N3A4UXpWeTlIWFdGR21XUGdsL2ZiUHZ6UGRsVXMK"
    }
  }
}
